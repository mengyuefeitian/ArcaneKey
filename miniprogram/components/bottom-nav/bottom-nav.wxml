<view class="nav-outer" style="transform:{{visible ? 'translateY(0)' : 'translateY(120%)'}}">
  <view class="nav-bar">
    <!-- 首页 -->
    <view class="nav-item {{current === 'home' ? 'active' : ''}}"
          data-screen="home" bindtap="onTap">
      <text class="nav-icon-text" style="font-size:20px;color:{{current === 'home' ? accentColor : 'rgba(238,238,245,0.38)'}}">⌂</text>
      <text class="nav-label" style="color:{{current === 'home' ? accentColor : 'rgba(238,238,245,0.38)'}}">首页</text>
    </view>

    <!-- 搜索 (紧跟首页) -->
    <view class="nav-item {{searching ? 'active' : ''}}"
          bindtap="onSearchTap">
      <text class="nav-icon-text" style="font-size:18px;color:{{searching ? accentColor : 'rgba(238,238,245,0.38)'}}">⌕</text>
      <text class="nav-label" style="color:{{searching ? accentColor : 'rgba(238,238,245,0.38)'}};font-weight:{{searching ? 650 : 400}}">搜索</text>
    </view>

    <!-- 扫码 -->
    <view class="nav-item {{current === 'scan' ? 'active' : ''}}"
          data-screen="scan" bindtap="onTap">
      <text class="nav-icon-text" style="font-size:20px;color:{{current === 'scan' ? accentColor : 'rgba(238,238,245,0.38)'}}">⊞</text>
      <text class="nav-label" style="color:{{current === 'scan' ? accentColor : 'rgba(238,238,245,0.38)'}}">扫码</text>
    </view>

    <!-- 我的 -->
    <view class="nav-item {{current === 'profile' ? 'active' : ''}}"
          data-screen="profile" bindtap="onTap">
      <text class="nav-icon-text" style="font-size:20px;color:{{current === 'profile' ? accentColor : 'rgba(238,238,245,0.38)'}}">☺</text>
      <text class="nav-label" style="color:{{current === 'profile' ? accentColor : 'rgba(238,238,245,0.38)'}}">我</text>
    </view>
  </view>
</view>
