.ring-wrap {
  position: relative;
  width: 34px;
  height: 34px;
  flex-shrink: 0;
}
.ring-num {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  font-weight: 700;
  font-family: system-ui, sans-serif;
  text-align: center;
  line-height: 34px;
  width: 34px;
}
