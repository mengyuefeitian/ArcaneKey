<view class="page" style="--accent:{{accentColor}}">

  <!-- ═══ HOME SCREEN ═══ -->
  <block wx:if="{{screen === 'home' && !showLoginModal && !showAccountModal && !editToken && !showQRCodeModal}}">
    <view class="screen">
      <!-- Header -->
      <view class="home-header">
        <block wx:if="{{searching}}">
          <view class="search-bar" style="border-color:{{accentColor}}55">
            <view class="search-icon-img"/>
            <input class="search-input" value="{{searchQ}}" bindinput="onSearchInput"
              placeholder="搜索品牌或账号…" placeholder-class="search-placeholder" focus="{{true}}"/>
            <view class="search-close" bindtap="onSearchClear">
              ×
            </view>
          </view>
        </block>
      </view>

      <!-- Token list -->
      <scroll-view class="token-list" style="padding-top:{{searching ? 0 : '8px'}}" scroll-y bindscroll="onHomeScroll" enhanced="{{true}}" show-scrollbar="{{false}}" scroll-top="{{scrollTop}}">
        <block wx:if="{{filteredTokens.length === 0}}">
          <view class="empty-state">
            <text class="empty-icon">🔍</text>
            <text class="empty-text">{{searchQ ? '未找到匹配账号' : '暂无验证码\n点击下方扫码添加'}}</text>
          </view>
        </block>
        <block wx:else>
          <token-card wx:for="{{filteredTokens}}" wx:key="id"
            token="{{item}}"
            otp="{{otpMap[item.id]}}"
            time-left="{{timeLeft}}"
            accent-color="{{accentColor}}"
            bind:edit="onEditToken"
            bind:copy="onCopyOtp"
          />
        </block>
        <view style="height:120px"/>
      </scroll-view>
    </view>
  </block>

  <!-- ═══ SCAN SCREEN ═══ -->
  <block wx:elif="{{screen === 'scan'}}">
    <view class="screen scan-screen">
      <!-- Header -->
      <view class="modal-header">
        <view class="icon-btn" bindtap="onCloseScan">×</view>
        <text class="modal-title">添加账号</text>
        <text wx:if="{{scanScanned}}" class="scanned-badge" style="color:{{accentColor}}">✓ 已识别</text>
      </view>

      <!-- Tabs -->
      <view class="tab-bar">
        <view wx:for="{{['camera','album','manual']}}" wx:key="*this"
          class="tab-item {{scanTab === item ? 'tab-active' : ''}}"
          data-tab="{{item}}" bindtap="onScanTabChange"
          style="background:{{scanTab === item ? accentColor : 'transparent'}};color:{{scanTab === item ? '#fff' : 'rgba(238,238,245,0.45)'}}">
          {{item === 'camera' ? '扫二维码' : item === 'album' ? '选相册' : '手动输入'}}
        </view>
      </view>

      <!-- Camera tab -->
      <block wx:if="{{scanTab === 'camera'}}">
        <view class="scan-content">
          <view class="camera-box">
            <view class="camera-bg"/>
            <view class="camera-overlay"/>
            <view class="scan-frame">
              <view class="corner tl" style="border-color:{{accentColor}}"/>
              <view class="corner tr" style="border-color:{{accentColor}}"/>
              <view class="corner bl" style="border-color:{{accentColor}}"/>
              <view class="corner br" style="border-color:{{accentColor}}"/>
              <view wx:if="{{scanScanning}}" class="scan-line" style="background:linear-gradient(90deg, transparent, {{accentColor}}, transparent);box-shadow:0 0 10px {{accentColor}}"/>
            </view>
          </view>
          <text class="scan-hint">{{scanScanning ? '正在识别二维码…' : '点击下方按钮扫描二维码'}}</text>
          <view class="primary-btn {{scanScanning ? 'btn-disabled' : ''}}"
            style="background:{{scanScanning ? 'rgba(255,255,255,0.07)' : accentColor}};color:{{scanScanning ? 'rgba(238,238,245,0.4)' : '#fff'}}"
            bindtap="onScanCamera">
            {{scanScanning ? '识别中…' : '扫描二维码'}}
          </view>
        </view>
      </block>

      <!-- Album tab -->
      <block wx:elif="{{scanTab === 'album'}}">
        <view class="scan-content" style="padding-top:36px;align-items:center;gap:18px">
          <view class="album-icon">🖼️</view>
          <text class="scan-hint" style="text-align:center">从相册中选择含二维码的图片<br/>自动识别并添加账号</text>
          <view class="primary-btn" style="background:{{accentColor}}" bindtap="onScanAlbum">选择图片</view>
        </view>
      </block>

      <!-- Manual tab -->
      <block wx:elif="{{scanTab === 'manual'}}">
        <scroll-view class="scan-content" scroll-y show-scrollbar="{{false}}">
          <view wx:if="{{scanScanned}}" class="scan-detected" style="background:{{accentColor}}18;border-color:{{accentColor}}30;color:{{accentColor}}">
            ✓ 已从二维码读取信息，请确认或修改
          </view>

          <!-- Brand -->
          <view class="field-wrap">
            <text class="field-label">品牌名称<text style="color:{{accentColor}}"> *</text></text>
            <input class="field-input {{scanErrors.brand ? 'field-error' : ''}}"
              value="{{scanForm.brand}}" data-field="brand" bindinput="onScanFormInput"
              placeholder="如 Google、Microsoft…" placeholder-class="search-placeholder"/>
            <text wx:if="{{scanErrors.brand}}" class="error-msg">{{scanErrors.brand}}</text>
          </view>

          <!-- Account -->
          <view class="field-wrap">
            <text class="field-label">账号信息</text>
            <input class="field-input" value="{{scanForm.account}}" data-field="account" bindinput="onScanFormInput"
              placeholder="邮箱、用户名等" placeholder-class="search-placeholder"/>
          </view>

          <!-- Secret -->
          <view class="field-wrap">
            <text class="field-label">Secret Key<text style="color:{{accentColor}}"> *</text></text>
            <input class="field-input mono {{scanErrors.secret ? 'field-error' : ''}}"
              value="{{scanForm.secret}}" data-field="secret" bindinput="onScanFormInput"
              placeholder="Base32 密钥，如 JBSWY3DP…" placeholder-class="search-placeholder"/>
            <text wx:if="{{scanErrors.secret}}" class="error-msg">{{scanErrors.secret}}</text>
          </view>

          <!-- Preview -->
          <view wx:if="{{scanForm.brand}}" class="preview-row">
            <logo brand="{{scanForm.brand}}" size="{{36}}"/>
            <view style="flex:1">
              <text style="font-size:14px;color:#eeeef5;font-weight:600">{{scanForm.brand}}</text>
              <text wx:if="{{scanForm.account}}" style="display:block;font-size:12px;color:rgba(238,238,245,0.4);margin-top:2px">{{scanForm.account}}</text>
            </view>
            <text style="font-size:11px;color:rgba(238,238,245,0.3)">预览</text>
          </view>

          <view class="primary-btn" style="background:{{accentColor}};margin-top:4px" bindtap="onAddToken">添加账号</view>
          <view style="height:100px"/>
        </scroll-view>
      </block>
    </view>
  </block>

  <!-- ═══ PROFILE SCREEN ═══ -->
  <block wx:elif="{{screen === 'profile'}}">
    <scroll-view class="screen" scroll-y show-scrollbar="{{false}}" bindscroll="onProfileScroll">
      <view style="padding:20px 20px 0">
        <!-- Product branding -->
        <view class="product-section">
          <image class="product-logo-img" src="/images/logo.png" mode="aspectFit"/>
          <text class="product-name">星枢令</text>
          <text class="product-subtitle">星枢令：身份验证器</text>
          <text class="product-desc">为你所有的重要账号配备一把动态数字密码，每30秒自动更新，让登录更安全便捷，有效防范密码泄露风险，守护你的数字资产安全。</text>
        </view>

        <!-- Account info -->
        <view class="account-section">
          <block wx:if="{{loggedIn}}">
            <view class="account-card" style="border-color:{{accentColor}}30">
              <view wx:if="{{userInfo.avatar}}" class="account-avatar-img-wrap">
                <image class="account-avatar-img" src="{{userInfo.avatar}}" mode="aspectFill"/>
              </view>
              <view wx:else class="account-avatar" style="background:{{accentColor}}">
                <text style="font-size:18px;color:#fff;font-weight:700">{{userInfo.name[0] || 'U'}}</text>
              </view>
              <view style="flex:1">
                <text style="font-size:15px;color:#eeeef5;font-weight:600">{{userInfo.name}}</text>
              </view>
            </view>
          </block>
          <block wx:else>
            <view class="login-prompt-card" bindtap="onLoginOpen">
              <text style="font-size:14px;color:rgba(238,238,245,0.55)">登录后解锁更多功能</text>
              <view class="login-btn" style="background:{{accentColor}};box-shadow:0 4px 20px {{accentColor}}55">
                <text style="color:#fff;font-size:14px;font-weight:600">登录账号</text>
              </view>
            </view>
          </block>
        </view>

        <!-- Menu -->
        <view class="menu-group">
          <view wx:for="{{[{id:'account',iconClass:'menu-icon-account',label:'账号管理',desc:loggedIn ? '管理你的账号信息' : '登录后可用',locked:true},{id:'sync',iconClass:'menu-icon-sync',label:'数据同步',desc:lastSyncTime || '云端同步',locked:true},{id:'backup',iconClass:'menu-icon-export',label:'备份数据',desc:'加密备份到云端',locked:true},{id:'import',iconClass:'menu-icon-import',label:'导入备份',desc:'从云端恢复',locked:true},{id:'theme',iconClass:'menu-icon-theme',label:'皮肤主题',desc:currentTheme.name,locked:false}]}}" wx:key="id" class="menu-item {{item.locked && !loggedIn ? 'menu-disabled' : ''}}"
              data-id="{{item.id}}" data-locked="{{item.locked}}" bindtap="onMenuTap">
            <view class="menu-icon-svg {{item.iconClass}}" style="background-color:{{accentColor}}"></view>
            <view style="flex:1">
              <text class="menu-label">{{item.label}}</text>
              <text class="menu-desc">{{item.locked && !loggedIn ? '登录后可用' : item.desc}}</text>
            </view>
            ›
            <view wx:if="{{item.id !== 'theme'}}" class="menu-divider"/>
          </view>
          <view class="menu-item" data-id="feedback" bindtap="onMenuTap">
            <view class="menu-icon-svg menu-icon-feedback" style="background-color:{{accentColor}}"></view>
            <view style="flex:1">
              <text class="menu-label">意见与建议</text>
              <text class="menu-desc">向我们反馈问题或建议</text>
            </view>
            ›
          </view>
        </view>

        <view wx:if="{{loggedIn}}" class="logout-btn" bindtap="onLogout">退出登录</view>

        <!-- ═══ ACCOUNT INFO MODAL ═══ -->
        <view wx:if="{{showAccountModal}}" class="full-modal">
          <view class="modal-header">
            <view class="icon-btn" bindtap="onCloseAccount">×</view>
            <text class="modal-title">账号信息</text>
          </view>
          <view style="padding:0 20px;display:flex;flex-direction:column;gap:16px;flex:1">
            <!-- Avatar -->
            <view style="display:flex;flex-direction:column;align-items:center;padding:20px 0">
              <image wx:if="{{userInfo.avatar}}" class="account-info-avatar-img" src="{{userInfo.avatar}}" mode="aspectFill"/>
              <view wx:else class="account-info-avatar-placeholder" style="background:{{accentColor}}">
                <text style="font-size:28px;color:#fff;font-weight:700">{{userInfo.name[0] || 'U'}}</text>
              </view>
            </view>
            <!-- Fields -->
            <view class="account-info-row">
              <text class="account-info-label">昵称</text>
              <text class="account-info-value">{{userInfo.name}}</text>
            </view>
            <!-- 修改昵称按钮 -->
            <view class="primary-btn" style="background:{{accentColor}};margin-top:8px" bindtap="onEditNicknameFromAccount">修改昵称</view>
          </view>
        </view>

        <text class="version-text">玄钥 v1.0.0</text>
      </view>
      <view style="height:100px"/>
    </scroll-view>
  </block>

  <!-- ═══ EDIT MODAL ═══ -->
  <view wx:if="{{editToken}}" class="full-modal">
    <view class="modal-header">
      <view class="icon-btn" bindtap="onCloseEdit">×</view>
      <text class="modal-title" style="flex:1">编辑账号</text>
    </view>
    <view style="padding:0 20px;flex:1;overflow-y:auto">
      <view style="display:flex;justify-content:center;padding:20px 0 8px">
        <logo brand="{{editForm.brand || editToken.brand}}" size="{{64}}"/>
      </view>
      <view class="field-wrap">
        <text class="field-label">品牌名称</text>
        <input class="field-input" value="{{editForm.brand}}" data-field="brand" bindinput="onEditFormInput" placeholder-class="search-placeholder"/>
      </view>
      <view class="field-wrap">
        <text class="field-label">账号信息</text>
        <input class="field-input" value="{{editForm.account}}" data-field="account" bindinput="onEditFormInput" placeholder-class="search-placeholder"/>
      </view>
      <view class="field-wrap">
        <text class="field-label">Secret Key</text>
        <input class="field-input mono" disabled value="{{editSecretVisible ? editToken.secret : editSecretMask}}" placeholder-class="search-placeholder"/>
        <!-- 操作按钮放在输入框下方 -->
        <view style="display:flex;gap:12px;margin-top:8px">
          <view class="secret-action-btn" style="color:{{accentColor}}" bindtap="onToggleEditSecret">
            {{editSecretVisible ? '👁️ 隐藏' : '👁️ 查看'}}
          </view>
          <view class="secret-action-btn" style="color:{{accentColor}}" bindtap="onShowQRCode">
            📱 二维码
          </view>
        </view>
      </view>
      <view style="height:20px"/>
    </view>
    <block wx:if="{{!confirmDelete}}">
      <view class="edit-bottom-bar">
        <view class="delete-btn-flat" bindtap="requestDeleteToken">删除账号</view>
        <view class="save-btn-flat" style="background:{{accentColor}}" bindtap="onSaveEdit">保存</view>
      </view>
    </block>
    <block wx:else>
      <view class="edit-bottom-bar">
        <view class="cancel-delete-btn-flat" bindtap="onCancelDelete">取消</view>
        <view class="confirm-delete-btn-flat" bindtap="onDeleteToken">确认删除</view>
      </view>
    </block>
  </view>

  <!-- ═══ LOGIN MODAL ═══ -->
  <view wx:if="{{showLoginModal}}" class="full-modal">
    <view class="modal-header">
      <view class="icon-btn" bindtap="onCloseLogin">×</view>
      <text class="modal-title">设置头像昵称</text>
    </view>
    <view style="padding:0 20px;flex:1;display:flex;flex-direction:column;gap:16px">
      <!-- 隐私协议同意 -->
      <view style="padding-top:16px">
        <view style="display:flex;align-items:center;gap:8px;padding:12px;background:#191920;border-radius:12px;border:1px solid {{loginPrivacyAgreed ? accentColor + '30' : 'rgba(255,255,255,0.05)'}}" bindtap="onLoginPrivacyToggle">
          <view style="width:20px;height:20px;min-width:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;border:1.5px solid {{loginPrivacyAgreed ? accentColor : 'rgba(238,238,245,0.3)'}};background:{{loginPrivacyAgreed ? accentColor : 'transparent'}}">
            <text wx:if="{{loginPrivacyAgreed}}" style="font-size:10px;color:#fff;font-weight:700">✓</text>
          </view>
          <text style="flex:1;font-size:13px;line-height:20px;color:{{loginPrivacyAgreed ? 'rgba(238,238,245,0.5)' : 'rgba(238,238,245,0.35)'}}">
            我已阅读并同意 <text style="color:{{accentColor}};font-weight:500">《用户协议》</text> 和 <text style="color:{{accentColor}};font-weight:500">《隐私保护协议》</text>
          </text>
        </view>
      </view>

      <!-- 头像和昵称设置（隐私同意后可见） -->
      <view wx:if="{{loginPrivacyAgreed}}" style="display:flex;flex-direction:column;align-items:center;gap:16px;padding-top:8px">
        <text wx:if="{{loggedIn}}" style="font-size:12px;color:{{accentColor}};text-align:center;font-weight:500">
          已登录，可修改头像和昵称
        </text>
        <text wx:else style="font-size:12px;color:{{accentColor}};text-align:center;font-weight:500">
          点击头像按钮即可获取微信头像
        </text>
        <button class="avatar-picker-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{loginAvatar}}" class="login-avatar-img" src="{{loginAvatar}}" mode="aspectFill"/>
          <image wx:else class="login-avatar-placeholder-img" src="/images/logo.png" mode="aspectFit"/>
          <text class="avatar-hint">{{loginAvatar ? '✓ 已获取' : '点击获取头像'}}</text>
        </button>
        <view class="field-wrap" style="width:100%">
          <text class="field-label">昵称（可修改）</text>
          <input class="field-input nickname-input" type="nickname" value="{{loginNickname}}"
            bindinput="onNicknameInput" bindfocus="onNicknameFocus" placeholder="可输入或使用微信昵称" placeholder-class="search-placeholder"/>
        </view>
        <!-- 使用微信昵称快捷按钮 -->
        <view style="width:100%;display:flex;gap:8px">
          <view style="flex:1;position:relative">
            <input style="width:100%;height:36px;border-radius:8px;background:rgba(238,238,245,0.08);border:1px solid rgba(238,238,245,0.1);color:rgba(238,238,245,0.35);font-size:12px;text-align:center" type="nickname" placeholder="" value="" bindinput="onUseWxNickname"/>
            <text style="position:absolute;top:0;left:0;right:0;height:36px;display:flex;align-items:center;justify-content:center;font-size:12px;color:rgba(238,238,245,0.45);pointer-events:none">使用微信昵称</text>
          </view>
        </view>
        <view class="primary-btn" style="background:{{loginAvatar ? accentColor : '#191920'}};color:{{loginAvatar ? '#fff' : 'rgba(238,238,245,0.3)'}}"
          bindtap="onSaveProfile">{{loginAvatar ? '保存设置' : '请先获取头像'}}</view>
      </view>

      <!-- 隐私未同意时的提示 -->
      <view wx:else style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:40px 0">
        <text style="font-size:14px;color:rgba(238,238,245,0.35);text-align:center">
          同意后，昵称将自动随机生成，头像需点击获取
        </text>
      </view>

      <view class="skip-btn" bindtap="onSkipLogin">暂不设置</view>
    </view>
  </view>


  <!-- ═══ BACKUP MODAL ═══ -->
  <view wx:if="{{showBackupModal}}" class="full-modal">
    <view class="modal-header">
      <view class="icon-btn" bindtap="onCloseBackup">×</view>
      <text class="modal-title">备份数据</text>
    </view>
    <view style="padding:0 20px;display:flex;flex-direction:column;gap:14px;flex:1">
      <view class="info-banner">ℹ️ 备份文件将使用您设置的密码加密。请牢记密码，忘记密码将无法恢复数据。</view>
      <view class="field-wrap">
        <text class="field-label">加密密码</text>
        <input class="field-input" password value="{{backupPw}}" bindinput="onBackupPwInput" placeholder="设置备份密码" placeholder-class="search-placeholder"/>
      </view>
      <view class="field-wrap">
        <text class="field-label">确认密码</text>
        <input class="field-input" password value="{{backupPw2}}" bindinput="onBackupPw2Input" placeholder="再次输入密码" placeholder-class="search-placeholder"/>
      </view>
      <text wx:if="{{backupPw && backupPw2 && backupPw !== backupPw2}}" style="font-size:12px;color:#f87171">两次密码不一致</text>
      <text style="font-size:13px;color:rgba(238,238,245,0.35)">将备份 {{tokens.length}} 个账号</text>
      <view class="primary-btn" style="margin-top:auto;background:{{backupPw && backupPw === backupPw2 ? accentColor : '#191920'}};color:{{backupPw && backupPw === backupPw2 ? '#fff' : 'rgba(238,238,245,0.3)'}}" bindtap="onDoBackup">加密备份</view>
    </view>
  </view>

  <!-- ═══ IMPORT MODAL ═══ -->
  <view wx:if="{{showImportModal}}" class="full-modal">
    <view class="modal-header">
      <view class="icon-btn" bindtap="onCloseImport">×</view>
      <text class="modal-title">导入备份</text>
    </view>
    <view style="padding:0 20px;display:flex;flex-direction:column;gap:14px;flex:1">
      <view class="field-wrap">
        <text class="field-label">选择备份文件</text>
        <view class="file-picker" style="border-color:{{importFileName ? accentColor + '50' : 'rgba(255,255,255,0.08)'}}" bindtap="onImportFileSelect">
          <text style="font-size:22px">📁</text>
          <text style="font-size:13px;color:{{importFileName ? '#eeeef5' : 'rgba(238,238,245,0.35)'}}">{{importFileName || '选择 .atbk 备份文件'}}</text>
        </view>
      </view>
      <view class="field-wrap">
        <text class="field-label">解密密码</text>
        <input class="field-input" password value="{{importPw}}" bindinput="onImportPwInput" placeholder="输入备份时设置的密码" placeholder-class="search-placeholder"/>
      </view>
      <view class="primary-btn" style="margin-top:auto;background:{{importRaw && importPw ? accentColor : '#191920'}};color:{{importRaw && importPw ? '#fff' : 'rgba(238,238,245,0.3)'}}" bindtap="onDoImport">解密并导入</view>
    </view>
  </view>

  <!-- ═══ THEME MODAL ═══ -->
  <view wx:if="{{showThemeModal}}" class="full-modal">
    <view class="modal-header">
      <view class="icon-btn" bindtap="onCloseTheme">×</view>
      <text class="modal-title">皮肤主题</text>
    </view>
    <view style="padding:8px 16px;display:grid;grid-template-columns:repeat(5, 1fr);gap:14px">
      <view wx:for="{{THEMES}}" wx:key="name" class="theme-swatch" data-idx="{{index}}" bindtap="onThemeSelect">
        <view class="swatch-circle" style="background:{{item.color}};border:{{currentTheme.name === item.name ? '3px solid #fff' : '3px solid transparent'}};box-shadow:{{currentTheme.name === item.name ? '0 0 18px ' + item.color : '0 4px 12px ' + item.color + '55'}}">
          <block wx:if="{{currentTheme.name === item.name}}">
            ✓
          </block>
        </view>
        <text class="swatch-name" style="color:{{currentTheme.name === item.name ? '#eeeef5' : 'rgba(238,238,245,0.45)'}};font-weight:{{currentTheme.name === item.name ? 600 : 400}}">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- ═══ SYNC CONFIG MODAL ═══ -->
  <view wx:if="{{showSyncModal}}" class="full-modal">
    <view class="modal-header">
      <view class="icon-btn" bindtap="onCloseSync">×</view>
      <text class="modal-title">数据同步</text>
    </view>
    <view style="padding:0 20px;flex:1;display:flex;flex-direction:column;gap:16px">
      <!-- Sync Status -->
      <view class="sync-config-card" style="border-color:{{accentColor}}20">
        <view style="flex:1">
          <text style="font-size:14px;color:#eeeef5;font-weight:500">同步状态</text>
          <text style="display:block;font-size:12px;color:rgba(238,238,245,0.35);margin-top:2px">
            {{lastSyncTime ? '上次同步：' + lastSyncTime : '尚未同步'}}
            <text wx:if="{{pendingSyncCount > 0}}" style="color:#f59e0b"> · {{pendingSyncCount}} 个待同步任务</text>
            <text wx:if="{{pendingUploadCount > 0}}" style="color:#f59e0b"> · {{pendingUploadCount}} 条待上传</text>
          </text>
        </view>
        <view style="width:8px;height:8px;border-radius:50%;background:{{lastSyncTime ? accentColor : 'rgba(238,238,245,0.2)'}}"></view>
      </view>

      <!-- Sync Toggle -->
      <view class="sync-config-card" style="border-color:rgba(255,255,255,0.08)">
        <view style="flex:1">
          <text style="font-size:14px;color:#eeeef5;font-weight:500">自动同步</text>
          <text style="display:block;font-size:12px;color:rgba(238,238,245,0.35);margin-top:2px">
            每30分钟从云端同步到本地
          </text>
        </view>
        <view class="sync-switch {{syncEnabled ? 'sync-switch-on' : ''}}" style="background:{{syncEnabled ? accentColor : 'rgba(255,255,255,0.1)'}}" bindtap="onToggleSync">
          <view class="sync-switch-dot" style="transform:translateX({{syncEnabled ? '20px' : '0'}})"></view>
        </view>
      </view>

      <!-- Manual Sync Button -->
      <view class="sync-config-card" style="border-color:rgba(255,255,255,0.08)">
        <view style="flex:1">
          <text style="font-size:14px;color:#eeeef5;font-weight:500">同步到本地</text>
          <text style="display:block;font-size:12px;color:rgba(238,238,245,0.35);margin-top:2px">
            立即从云端拉取最新数据
          </text>
        </view>
        <view class="sync-btn {{syncStatus === 'syncing' ? 'sync-btn-loading' : ''}}"
          style="background:{{syncStatus === 'syncing' ? '#191920' : accentColor}};color:{{syncStatus === 'syncing' ? 'rgba(238,238,245,0.4)' : '#fff'}}"
          bindtap="onSyncToLocal">
          {{syncStatus === 'syncing' ? '同步中...' : '立即同步'}}
        </view>
      </view>

      <!-- Sync Info -->
      <view class="info-banner">ℹ️ 自动同步以云端数据为准。本地新增数据会优先上传到云端，上传成功后才会从云端同步到本地。</view>

      <!-- Upload Pending -->
      <view wx:if="{{pendingUploadCount > 0}}" class="sync-config-card" style="border-color:#f59e0b30">
        <view style="flex:1">
          <text style="font-size:14px;color:#f59e0b;font-weight:500">待上传数据</text>
          <text style="display:block;font-size:12px;color:rgba(238,238,245,0.35);margin-top:2px">
            {{pendingUploadCount}} 条本地新增数据待上传
          </text>
        </view>
        <view class="sync-btn" style="background:{{accentColor}};color:#fff" bindtap="onUploadToCloud">
          立即上传
        </view>
      </view>
    </view>
  </view>

  <!-- ═══ DELETE CONFIRMATION MODAL ═══ -->
  <view wx:if="{{showDeleteModal}}" class="delete-modal-overlay">
    <view class="delete-dialog">
      <text class="delete-title">确认删除</text>
      <text class="delete-content">确定要删除「{{deleteTarget.brand}}」吗？{{loggedIn ? '\n可选择同步删除云端数据' : ''}}</text>
      <block wx:if="{{loggedIn}}">
        <view class="delete-btns">
          <view class="delete-btn local" bindtap="executeDeleteLocal">仅本地</view>
          <view class="delete-btn cloud" bindtap="executeDeleteCloud">本地+云端</view>
          <view class="delete-btn cancel" bindtap="cancelDelete">取消</view>
        </view>
      </block>
      <block wx:else>
        <view class="delete-btns">
          <view class="delete-btn cancel" bindtap="cancelDelete">取消</view>
          <view class="delete-btn confirm" bindtap="executeDelete">删除</view>
        </view>
      </block>
    </view>
  </view>

  <!-- ═══ QR CODE MODAL ═══ -->
  <view wx:if="{{showQRCodeModal}}" class="delete-modal-overlay" bindtap="onCloseQRCode">
    <view class="delete-dialog" style="padding: 24px; width: 85%; max-width: 320px;" catchtap="">
      <text class="delete-title">分享二维码</text>
      <text class="delete-content" style="margin-bottom: 20px;">扫描此二维码可添加「{{editToken.brand}}」账号</text>
      <view class="qr-box" style="width: 256px; height: 256px; margin: 0 auto; background: #fff; border-radius: 8px;">
        <canvas type="2d" id="qrcode-canvas" style="width: 256px; height: 256px;"></canvas>
      </view>
      <text style="font-size: 12px; color: rgba(238,238,245,0.35); margin-top: 12px; text-align: center; display: block;">支持 Google Authenticator / Authy 等 TOTP 应用扫描</text>
      <view style="margin-top: 20px;">
        <view class="delete-btn cancel" style="width: 100%;" bindtap="onCloseQRCode">关闭</view>
      </view>
    </view>
  </view>

  <!-- Bottom nav & toast (always visible) -->
  <bottom-nav current="{{screen}}" visible="{{navVisible}}" accent-color="{{accentColor}}" searching="{{searching}}" bind:navigate="onNavigate" bind:searchtoggle="onSearchToggle" bind:searchclose="onSearchClose"/>
  <toast message="{{toast}}" type="{{toastType}}"/>
</view>