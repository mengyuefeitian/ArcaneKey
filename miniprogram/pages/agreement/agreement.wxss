.page {
  background: #0d0d12;
  min-height: 100vh;
}

.container {
  padding: 24px 20px 60px;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.main-title {
  font-size: 22px;
  font-weight: 700;
  color: #eeeef5;
  margin-bottom: 6px;
  display: block;
}

.update-date {
  font-size: 12px;
  color: rgba(238,238,245,0.35);
  margin-bottom: 24px;
  display: block;
}

.section {
  margin-bottom: 20px;
}

.section-heading {
  font-size: 15px;
  font-weight: 600;
  color: #eeeef5;
  margin-bottom: 8px;
  display: block;
}

.section-body {
  font-size: 14px;
  line-height: 1.7;
  color: rgba(238,238,245,0.65);
  display: block;
  white-space: pre-wrap;
}
