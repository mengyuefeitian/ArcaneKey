<scroll-view class="page" scroll-y>
  <view class="container">
    <text class="main-title">{{title}}</text>
    <text class="update-date">更新日期：2026年6月27日</text>
    <view wx:for="{{sections}}" wx:key="heading" class="section">
      <text class="section-heading">{{item.heading}}</text>
      <text class="section-body">{{item.body}}</text>
    </view>
  </view>
</scroll-view>
